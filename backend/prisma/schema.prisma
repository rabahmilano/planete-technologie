// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categorie {
  id_cat          Int    @id
  designation_cat String @db.VarChar(50)

  colis colis[]
}

model colis {
  id_colis      Int       @id
  cat_id        Int
  prd_id        Int
  cpt_id        Int
  mnt_tot_dev   Decimal   @db.Decimal(10, 4)
  date_achat    DateTime? @db.Date()
  date_stock    DateTime? @db.Date()
  qte_achat     Int
  qte_stock     Int?
  droits_timbre Boolean?
  mnt_tot_dzd   Decimal   @db.Decimal(10, 4)
  pu_dev        Decimal   @db.Decimal(10, 4)
  pu_dzd        Decimal   @db.Decimal(10, 4)
  pu_dzd_ttc    Decimal   @db.Decimal(10, 4)

  lignes    ligne_commande_colis[]
  categorie categorie              @relation(fields: [cat_id], references: [id_cat])
  produit   produit                @relation(fields: [prd_id], references: [id_prd])
  compte    compte                 @relation(fields: [cpt_id], references: [id_cpt])

  colis_classique      colis_classique?
  colis_voyage         colis_voyage?
}

model colis_classique {
  id_colis_class       Int       @id
  date_achat           DateTime  @db.Date()
  droits_timbre        Boolean?
  frais_bancaires      Decimal?  @db.Decimal(10, 4) 

  colis                colis     @relation(fields: [id_colis_class], references: [id_colis])
}

model colis_voyage {
  id_colis_voy          Int      @id
  transaction_id        Int
  pu_devise_dest        Decimal  @db.Decimal(10, 2) // Prix d'achat unitaire en devise de destination (ex: CNY)
  mnt_tot_dev_dest      Decimal  @db.Decimal(10, 2) // Montant total (ex: CNY)
  pu_dev_ttc            Decimal  @db.Decimal(10, 4) // Prix unitaire final dans la devise de la carte (ex: EUR)
  mnt_dev_ttc           Decimal  @db.Decimal(10, 4) // Montant total final dans la devise de la carte (ex: EUR)

  colis                 colis              @relation(fields: [id_colis_voy], references: [id_colis])
  transaction           transaction_voyage @relation(fields: [transaction_id], references: [id_transaction])
}

model produit {
  id_prd          Int    @id
  designation_prd String @db.VarChar(150)
  qte_dispo       Int    @default(0)

  colis          colis[]
  ligne_commande ligne_commande[]
}

model commande {
  id_cde   Int      @id
  date_cde DateTime @db.Date()
  mnt_cde  Decimal  @db.Decimal(10, 4)

  ligne_commande ligne_commande[]
}

model ligne_commande {
  cde_id   Int
  prd_id   Int
  qte_cde  Int
  pu_vente Decimal @db.Decimal(10, 4)

  colis    ligne_commande_colis[]
  commande commande               @relation(fields: [cde_id], references: [id_cde])
  produit  produit                @relation(fields: [prd_id], references: [id_prd])

  @@id([cde_id, prd_id])
}

model ligne_commande_colis {
  cde_id   Int
  prd_id   Int
  colis_id Int
  qte      Int

  ligne_commande ligne_commande @relation(fields: [cde_id, prd_id], references: [cde_id, prd_id])
  colis          colis          @relation(fields: [colis_id], references: [id_colis])

  @@id([cde_id, prd_id, colis_id])
}

model compte {
  id_cpt             Int     @id
  dev_code           String  @db.Char(4)
  type_cpt           String  @db.VarChar(50)
  designation_cpt    String  @db.VarChar(50)
  commission_pct     Decimal @default(0.00) @db.Decimal(5, 2)
  solde_actuel       Decimal @default(0.00) @db.Decimal(10, 2)
  taux_change_actuel Decimal @default(0.00) @db.Decimal(10, 2)

  colis          colis[]
  depenses       depense[]
  crediter       crediter[]
  emprunts       emprunt[]
  remboursements remboursement[]
  voyages_defaut      voyage[]
  transactions_voyage transaction_voyage[]

  devise         devise     @relation(fields: [dev_code], references: [code_dev])
}

model crediter {
  id_op_crd   Int      @id
  cpt_id      Int
  date_op     DateTime @db.Date()
  montant_op  Decimal  @db.Decimal(10, 2)
  taux_change Decimal  @db.Decimal(10, 2)

  compte compte @relation(fields: [cpt_id], references: [id_cpt])
}

model devise {
  code_dev    String @id @db.Char(4)
  nom_dev     String @db.VarChar(20)
  symbole_dev String @db.VarChar(3)

  compte compte[]
}

model depense {
  id_op_dep   Int      @id
  cpt_id      Int
  nat_dep_id  Int
  date_dep    DateTime @db.Date()
  mnt_dep     Decimal  @db.Decimal(12, 4)
  mnt_dep_dzd Decimal  @db.Decimal(12, 4)

  voyage_id   Int?
  observation String?  @db.VarChar(255)
  isAnnule    Boolean  @default(false)

  compte     compte     @relation(fields: [cpt_id], references: [id_cpt])
  nature_dep nature_dep @relation(fields: [nat_dep_id], references: [id_nat_dep])
  voyage     voyage?    @relation(fields: [voyage_id], references: [id_voyage])
}

model nature_dep {
  id_nat_dep          Int    @id
  designation_nat_dep String @db.VarChar(50)

  depense depense[]
}

enum StatutEmprunt {
  EN_COURS
  SOLDE
}

model emprunt {
  id_emprunt      Int             @id
  designation     String          @db.VarChar(255)
  montant_emprunt Decimal         @db.Decimal(10, 2)
  date_emprunt    DateTime        @db.Date()
  cpt_id          Int       
  statut_emprunt  StatutEmprunt   @default(EN_COURS)
  
  remboursements  remboursement[] 

  compte          compte          @relation(fields: [cpt_id], references: [id_cpt])
}

model remboursement {
  id_remb       Int       @id
  montant_remb  Decimal   @db.Decimal(10, 2)
  date_remb     DateTime  @db.Date()
  emprunt_id    Int
  cpt_remb      Int

  emprunt       emprunt   @relation(fields: [emprunt_id], references: [id_emprunt])
  compte        compte    @relation(fields: [cpt_remb], references: [id_cpt])
}

model voyage {
  id_voyage            Int                  @id
  designation          String
  destination          String?
  date_depart          DateTime             @db.Date()
  date_retour          DateTime             @db.Date()
  statut               StatutVoyage         @default(EN_PREPARATION)

  devise_destination   String               @default("CNY")
  taux_change_devise   Decimal?             @db.Decimal(10, 2) // Rempli avant de passer EN_COURS
  coefficient_approche Decimal?             @db.Decimal(10, 4) // Rempli à la clôture

  // Le compte utilisé par défaut pour ce voyage (UX)
  compte_defaut_id     Int?

  transactions         transaction_voyage[]
  depenses             depense[]

  compte_defaut        compte?              @relation(fields: [compte_defaut_id], references: [id_cpt])
}

enum StatutVoyage {
  EN_PREPARATION
  EN_COURS
  CLOTURE
}

model transaction_voyage {
  id_transaction       Int            @id
  voyage_id            Int
  compte_id            Int            
  fournisseur          String?
  devise_transaction   String         @default("CNY") // Permet l'exception (ex: paiement USD)
  taux_transaction     Decimal        @db.Decimal(10, 2) // Taux DZD figé pour cette facture
  montant_total        Decimal        @db.Decimal(10, 4) // Total de contrôle de la facture
  commission_banque    Decimal        @default(0) @db.Decimal(5, 2) // Pourcentage (ex: 2.00)
  commission_paiement  Decimal        @default(0) @db.Decimal(10, 4) // Montant réel prélevé (ex: Alipay)

  colis_voyage         colis_voyage[]

  compte               compte         @relation(fields: [compte_id], references: [id_cpt])
  voyage               voyage         @relation(fields: [voyage_id], references: [id_voyage])
}